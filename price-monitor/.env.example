# ── Email (Gmail recommended) ─────────────────────────────────────────────────
# Create a Gmail App Password at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx      # 16-char App Password (spaces are fine)
ALERT_TO=your.email@gmail.com      # Where to send alerts (can be same as above)

# ── Optional: Slack / Discord / generic webhook ───────────────────────────────
# Slack:   https://api.slack.com/messaging/webhooks
# Discord: Server Settings → Integrations → Webhooks
# Leave blank to skip webhook notifications.

WEBHOOK_URL=
