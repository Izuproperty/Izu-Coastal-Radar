# ── Choose ONE of the email providers below ───────────────────────────────────

# ── Option A: Mac.com / iCloud Mail ──────────────────────────────────────────
# App-specific password: appleid.apple.com → Sign-In & Security → App-Specific Passwords
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=you@mac.com           # or @icloud.com or @me.com — all work
SMTP_PASS=xxxx-xxxx-xxxx-xxxx   # 16-char app-specific password (hyphens are fine)
ALERT_TO=you@mac.com            # where to receive alerts (can be same address)

# ── Option B: Yahoo Mail ──────────────────────────────────────────────────────
# App password: login.yahoo.com → Security → Generate app password → "Other app"
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_USER=you@yahoo.com
# SMTP_PASS=xxxxxxxxxxxxxxxx    # 16-char app password (no spaces)
# ALERT_TO=you@yahoo.com

# ── Option C: Gmail ───────────────────────────────────────────────────────────
# App password: myaccount.google.com/apppasswords (requires 2-Step Verification)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx  # 16-char app password
# ALERT_TO=you@gmail.com

# ── Optional: Slack / Discord / generic webhook ───────────────────────────────
# Leave blank to skip.
WEBHOOK_URL=
